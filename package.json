{
  "name": "site-behavior-lab",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "build:pages": "node scripts/build-github-pages.mjs",
    "cf:bucket:create": "wrangler r2 bucket create site-behavior-lab-reports",
    "cf:deploy": "wrangler deploy -c wrangler.jsonc",
    "cf:dev": "wrangler dev -c wrangler.jsonc",
    "cf:kv:create": "wrangler kv namespace create site-behavior-lab-reports",
    "cf:typecheck": "tsc -p tsconfig.cloudflare.json --noEmit",
    "lists:brave": "node scripts/fetch-brave-lists.mjs",
    "check": "npm run typecheck && npm run cf:typecheck && npm run test:unit && npm run build",
    "corpus:stats": "node scripts/build-corpus-stats.mjs",
    "reports:manifest": "node scripts/build-static-report-manifest.mjs",
    "reports:prune": "node scripts/prune-static-reports.mjs",
    "scan:ci": "node scripts/run-ci-scan.mjs",
    "scan:featured": "node scripts/run-featured-scans.mjs",
    "start": "next start",
    "test:smoke:static": "node scripts/smoke-static-site.mjs",
    "test:smoke:docker": "node scripts/smoke-docker.mjs",
    "test:unit": "rm -rf .unit-test-dist && tsc -p tsconfig.test.json && node --test --test-concurrency=1 .unit-test-dist/lib/*.test.js",
    "test:smoke": "node scripts/smoke-test.mjs",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.0.4",
    "playwright": "1.61.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tldts": "^7.4.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@cloudflare/playwright": "^1.3.0",
    "@cloudflare/workers-types": "^4.20260619.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.103.0"
  }
}
