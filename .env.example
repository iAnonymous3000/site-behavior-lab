# Require a caller-provided key for /api/scan.
# Leave unset only for trusted local development or intentionally public deployments.
SITE_BEHAVIOR_LAB_SCAN_ACCESS_TOKEN=

# Trust x-real-ip / x-forwarded-for only when a trusted proxy blocks direct origin access.
SITE_BEHAVIOR_LAB_TRUST_PROXY_HEADERS=0

# Human-readable egress label included in scan reports.
SITE_BEHAVIOR_LAB_SCANNER_EGRESS=iad-lab-egress

# Return 202 job submissions from /api/scan and poll /api/scans/:id.
# This is single-process, in-memory queueing for one Node instance.
SITE_BEHAVIOR_LAB_ASYNC_SCANS=0

# Report storage backend: "filesystem" (default) or "r2".
# "filesystem" needs a persistent volume to survive restarts; "r2" stores reports
# in Cloudflare R2 so share links survive container redeploys and host replacement
# (and is what multi-node hosting needs).
SITE_BEHAVIOR_LAB_REPORT_STORE_BACKEND=filesystem

# Filesystem backend: use a persistent volume in production.
SITE_BEHAVIOR_LAB_REPORT_STORE_DIR=/var/lib/site-behavior-lab/reports
SITE_BEHAVIOR_LAB_REPORT_MAX_AGE_DAYS=7
SITE_BEHAVIOR_LAB_REPORT_MAX_COUNT=500

# R2 backend (S3-compatible), required when REPORT_STORE_BACKEND=r2.
# Endpoint looks like https://<accountid>.r2.cloudflarestorage.com
# Use an R2 API token scoped to the reports bucket (Object Read & Write).
SITE_BEHAVIOR_LAB_R2_BUCKET=site-behavior-lab-reports
SITE_BEHAVIOR_LAB_R2_ENDPOINT=
SITE_BEHAVIOR_LAB_R2_ACCESS_KEY_ID=
SITE_BEHAVIOR_LAB_R2_SECRET_ACCESS_KEY=
SITE_BEHAVIOR_LAB_R2_PREFIX=reports/

# Canonical public origin (scheme + host only) used at build time so report
# social cards (Open Graph / X) resolve to absolute image URLs. Without it,
# card image URLs fall back to http://localhost:3000 and will not unfurl.
NEXT_PUBLIC_SITE_BEHAVIOR_LAB_SITE_URL=

# Cloudflare Worker scanner.
# Gated by default. Set both of these to 1 only for an intentionally public
# Worker after accepting the documented Browser Run DNS-rebinding limitation.
SITE_BEHAVIOR_LAB_ALLOW_UNAUTHENTICATED_SCANS=0
SITE_BEHAVIOR_LAB_ACCEPT_BROWSER_RUN_DNS_REBINDING_RISK=0
SITE_BEHAVIOR_LAB_PUBLIC_SCAN_RATE_LIMIT_PER_MINUTE=6
SITE_BEHAVIOR_LAB_PUBLIC_SCAN_RATE_LIMIT_PER_DAY=120
# Optional gated deployments can instead set these as Worker secrets:
#   wrangler secret put SITE_BEHAVIOR_LAB_SCAN_ACCESS_TOKEN
#   wrangler secret put TURNSTILE_SECRET_KEY
# When TURNSTILE_SECRET_KEY is set on the Worker, the static UI also needs the
# matching public Turnstile site key at build time, or scans will be blocked.
NEXT_PUBLIC_SITE_BEHAVIOR_LAB_TURNSTILE_SITE_KEY=
# Defaults to https://cloudflare-dns.com/dns-query when unset.
SITE_BEHAVIOR_LAB_DNS_RESOLVER_URL=
SITE_BEHAVIOR_LAB_ALLOWED_ORIGIN=*
